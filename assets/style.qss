/* TraderOS Terminal - Dark Trading Theme */

/* Global */
QMainWindow, QWidget {
    background-color: #0D1117;
    color: #E0E0E0;
    font-family: "Consolas", "Courier New", monospace;
    font-size: 12px;
}

QDialog {
    background-color: #161B22;
    color: #E0E0E0;
}

/* Menu Bar */
QMenuBar {
    background-color: #161B22;
    color: #E0E0E0;
    border-bottom: 1px solid #30363D;
    padding: 2px;
}
QMenuBar::item:selected {
    background-color: #1F6FEB;
    border-radius: 3px;
}
QMenu {
    background-color: #161B22;
    border: 1px solid #30363D;
    color: #E0E0E0;
}
QMenu::item:selected {
    background-color: #1F6FEB;
}

/* Status Bar */
QStatusBar {
    background-color: #161B22;
    border-top: 1px solid #30363D;
    color: #8B949E;
    font-size: 11px;
}

/* Splitters */
QSplitter::handle {
    background-color: #21262D;
    width: 2px;
    height: 2px;
}
QSplitter::handle:hover {
    background-color: #1F6FEB;
}

/* Tree Header */
#treeHeader {
    background-color: #161B22;
    border-bottom: 1px solid #30363D;
}
#treePanelTitle {
    color: #8B949E;
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 2px;
}

/* Search Bar */
#searchBar {
    background-color: #21262D;
    border: 1px solid #30363D;
    border-radius: 4px;
    color: #E0E0E0;
    padding: 4px 8px;
    margin: 4px;
}
#searchBar:focus {
    border-color: #1F6FEB;
}

/* Strategy Tree */
#strategyTree {
    background-color: #0D1117;
    border: none;
    color: #E0E0E0;
}
#strategyTree::item {
    padding: 3px 2px;
    border-radius: 3px;
}
#strategyTree::item:hover {
    background-color: #21262D;
}
#strategyTree::item:selected {
    background-color: #1F6FEB30;
    color: #E0E0E0;
}

/* Icon Buttons */
#iconButton {
    background-color: transparent;
    border: none;
    color: #8B949E;
    font-size: 14px;
    padding: 2px 4px;
    border-radius: 3px;
}
#iconButton:hover {
    color: #E0E0E0;
    background-color: #21262D;
}

/* Panel Header */
#panelHeader {
    background-color: #161B22;
    border-bottom: 1px solid #30363D;
    color: #8B949E;
    font-size: 11px;
    padding: 8px 12px;
}

/* Metric Cards */
#metricCard {
    background-color: #161B22;
    border: 1px solid #21262D;
    border-radius: 6px;
    min-width: 90px;
    min-height: 56px;
}
#metricCard:hover {
    border-color: #30363D;
}
#metricValue {
    font-size: 16px;
    font-weight: bold;
    color: #E0E0E0;
}
#metricName {
    font-size: 9px;
    color: #8B949E;
    letter-spacing: 1px;
}

/* Action Buttons */
#actionButton {
    background-color: #1F6FEB;
    border: none;
    border-radius: 5px;
    color: white;
    padding: 6px 14px;
    font-weight: bold;
    font-size: 12px;
}
#actionButton:hover {
    background-color: #388BFD;
}
#actionButton:pressed {
    background-color: #1158C7;
}

#secondaryButton {
    background-color: #21262D;
    border: 1px solid #30363D;
    border-radius: 5px;
    color: #8B949E;
    padding: 6px 14px;
    font-size: 12px;
}
#secondaryButton:hover {
    color: #E0E0E0;
    border-color: #8B949E;
}

/* Tabs */
#dataTabs, #bottomTabs {
    background-color: #0D1117;
}
QTabWidget::pane {
    border: none;
    background-color: #0D1117;
}
QTabBar::tab {
    background-color: #161B22;
    color: #8B949E;
    padding: 6px 14px;
    border: none;
    border-bottom: 2px solid transparent;
    font-size: 11px;
}
QTabBar::tab:selected {
    color: #E0E0E0;
    border-bottom: 2px solid #1F6FEB;
    background-color: #0D1117;
}
QTabBar::tab:hover {
    color: #E0E0E0;
    background-color: #21262D;
}

/* West-side tabs (bottom panel) */
#bottomTabs QTabBar::tab {
    border-bottom: none;
    border-right: 2px solid transparent;
    text-align: center;
    min-width: 60px;
    padding: 8px 6px;
    font-size: 10px;
}
#bottomTabs QTabBar::tab:selected {
    border-right: 2px solid #1F6FEB;
    border-bottom: none;
}

/* Data Table */
#dataTable {
    background-color: #0D1117;
    alternate-background-color: #161B22;
    color: #E0E0E0;
    border: none;
    gridline-color: #21262D;
    selection-background-color: #1F6FEB30;
}
#dataTable QHeaderView::section {
    background-color: #161B22;
    color: #8B949E;
    border: none;
    border-bottom: 1px solid #30363D;
    padding: 4px 8px;
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 1px;
}

/* Overview / Params Text */
#overviewText {
    background-color: #0D1117;
    color: #E0E0E0;
    border: none;
    font-family: "Consolas", monospace;
    font-size: 12px;
    padding: 12px;
}

/* Claude Terminal */
#terminalHeader {
    background-color: #0A0E14;
    border-bottom: 1px solid #21262D;
}
#terminalTitle {
    color: #A5D6A7;
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 2px;
}
#contextLabel {
    color: #8B949E;
    font-size: 10px;
}

#chatDisplay {
    background-color: #090D13;
    color: #E0E0E0;
    border: none;
    font-family: "Consolas", monospace;
    font-size: 12px;
    padding: 8px;
}

#quickBar {
    background-color: #0A0E14;
    border-top: 1px solid #21262D;
}
#quickLabel {
    color: #8B949E;
    font-size: 10px;
}
#quickPromptBtn {
    background-color: #161B22;
    border: 1px solid #30363D;
    border-radius: 12px;
    color: #8B949E;
    padding: 3px 10px;
    font-size: 10px;
}
#quickPromptBtn:hover {
    color: #A5D6A7;
    border-color: #A5D6A7;
}

#inputBar {
    background-color: #0A0E14;
    border-top: 1px solid #21262D;
}
#chatInput {
    background-color: #161B22;
    border: 1px solid #30363D;
    border-radius: 4px;
    color: #E0E0E0;
    padding: 6px 10px;
    font-family: "Consolas", monospace;
    font-size: 12px;
}
#chatInput:focus {
    border-color: #A5D6A7;
}
#sendButton {
    background-color: #2E7D32;
    border: none;
    border-radius: 4px;
    color: white;
    padding: 6px 16px;
    font-weight: bold;
}
#sendButton:hover {
    background-color: #388E3C;
}
#sendButton:disabled {
    background-color: #1B3A1E;
    color: #555;
}

#clearButton {
    background-color: transparent;
    border: 1px solid #30363D;
    border-radius: 3px;
    color: #8B949E;
    padding: 2px 8px;
    font-size: 10px;
}
#clearButton:hover {
    color: #E0E0E0;
    border-color: #8B949E;
}

/* Browser */
#browserHeader {
    background-color: #0D1117;
    border-bottom: 1px solid #21262D;
}
#browserTitle {
    color: #64B5F6;
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 2px;
}
#navBar {
    background-color: #161B22;
    border-bottom: 1px solid #21262D;
}
#navButton {
    background-color: transparent;
    border: none;
    color: #8B949E;
    font-size: 14px;
    padding: 3px 6px;
    border-radius: 3px;
}
#navButton:hover {
    color: #E0E0E0;
    background-color: #21262D;
}
#addressBar {
    background-color: #21262D;
    border: 1px solid #30363D;
    border-radius: 4px;
    color: #E0E0E0;
    padding: 4px 8px;
    font-family: "Consolas", monospace;
    font-size: 11px;
}
#addressBar:focus {
    border-color: #64B5F6;
}
#goButton {
    background-color: #1F6FEB;
    border: none;
    border-radius: 4px;
    color: white;
    padding: 4px 12px;
}
#goButton:hover {
    background-color: #388BFD;
}
#linksBar {
    background-color: #0D1117;
    border-bottom: 1px solid #21262D;
}
#quickLinkBtn {
    background-color: transparent;
    border: none;
    color: #64B5F6;
    padding: 2px 8px;
    font-size: 11px;
    text-decoration: underline;
}
#quickLinkBtn:hover {
    color: #388BFD;
}
#browserProgress {
    background-color: #21262D;
    border: none;
}
#browserProgress::chunk {
    background-color: #1F6FEB;
}

/* Context Menu */
#contextMenu {
    background-color: #161B22;
    border: 1px solid #30363D;
}

/* Group Boxes */
QGroupBox {
    border: 1px solid #30363D;
    border-radius: 5px;
    margin-top: 8px;
    color: #8B949E;
    font-size: 11px;
    font-weight: bold;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 8px;
    padding: 0 4px;
}

/* Input Widgets */
QLineEdit, QSpinBox, QDoubleSpinBox {
    background-color: #21262D;
    border: 1px solid #30363D;
    border-radius: 4px;
    color: #E0E0E0;
    padding: 4px 8px;
}
QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: #1F6FEB;
}

QCheckBox {
    color: #E0E0E0;
    spacing: 6px;
}
QCheckBox::indicator {
    width: 14px;
    height: 14px;
    background-color: #21262D;
    border: 1px solid #30363D;
    border-radius: 3px;
}
QCheckBox::indicator:checked {
    background-color: #1F6FEB;
    border-color: #1F6FEB;
}

/* Dialog Buttons */
QDialogButtonBox QPushButton {
    background-color: #21262D;
    border: 1px solid #30363D;
    border-radius: 4px;
    color: #E0E0E0;
    padding: 6px 16px;
    min-width: 70px;
}
QDialogButtonBox QPushButton:hover {
    background-color: #30363D;
}
QDialogButtonBox QPushButton[text="OK"],
QDialogButtonBox QPushButton[text="Save"] {
    background-color: #1F6FEB;
    border-color: #1F6FEB;
    color: white;
}

/* ScrollBars */
QScrollBar:vertical {
    background-color: #0D1117;
    width: 8px;
}
QScrollBar::handle:vertical {
    background-color: #30363D;
    border-radius: 4px;
    min-height: 30px;
}
QScrollBar::handle:vertical:hover {
    background-color: #8B949E;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}
QScrollBar:horizontal {
    background-color: #0D1117;
    height: 8px;
}
QScrollBar::handle:horizontal {
    background-color: #30363D;
    border-radius: 4px;
    min-width: 30px;
}
QScrollBar::handle:horizontal:hover {
    background-color: #8B949E;
}

/* Tooltips */
QToolTip {
    background-color: #161B22;
    border: 1px solid #30363D;
    color: #E0E0E0;
    padding: 4px 8px;
    font-family: "Consolas", monospace;
    font-size: 11px;
}

/* Status NT8 indicator */
#statusNT8 {
    font-size: 11px;
    font-weight: bold;
    padding: 0 8px;
}

/* Fallback browser */
#fallbackBrowser {
    background-color: #0D1117;
    border: none;
}
